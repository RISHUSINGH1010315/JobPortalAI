# Database
DATABASE_URL="postgresql://jobpilot:password123@localhost:5432/jobpilot_db?schema=public"

# Clerk Authentication (Get these from your Clerk Dashboard)
# Frontend variables (copied to apps/web/.env)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Cloudinary (Get these from your Cloudinary Dashboard)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# AI Models (Plug in keys for OpenAI and/or Google Gemini)
OPENAI_API_KEY=sk-proj-...
GEMINI_API_KEY=AIzaSy...

# Port Configuration
PORT=4000
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000

# Stripe (Optional, for billing system)
# Set to 'mock' to use internal mock payment flow
BILLING_PROVIDER=mock
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
